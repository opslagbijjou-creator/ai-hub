{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": []
  },
  "include": [
    "src/**/*",
    "supabase/functions/**/*.ts",
    "supabase/functions/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "server"
  ]
}
